@model IEnumerable<KeeleSystem.Models.Enrollment>

<h2>Registreerimised (Admin)</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">
        @TempData["Message"]
    </div>
}

@if (!Model.Any())
{
    <p>Pole ühtegi registreerimist.</p>
}
else
{
    <table class="table table-striped">
        <tr>
            <th>Kursus</th>
            <th>Õpetaja</th>
            <th>Õpilane</th>
            <th>Staatus</th>
            <th></th>
        </tr>

        @foreach (var e in Model)
        {
            <tr>
                <td>@e.Training.Course.Nimetus</td>
                <td>@e.Training.Teacher.Nimi</td>
                <td>@(e.User != null ? e.User.Email : e.ApplicationUserId)</td>
                <td>
                    <span class="badge @(e.Status == "Kinnitatud" ? "badge-success" : e.Status == "Tühistatud" ? "badge-danger" : "badge-warning")">
                        @e.Status
                    </span>
                </td>
                <td>
                    @if (e.Status == "Ootel")
                    {
                        <a class="btn btn-sm btn-success" href="@Url.Action("Confirm", "AdminEnrollments", new { id = e.Id })">Kinnita</a>
                        <a class="btn btn-sm btn-danger" href="@Url.Action("Cancel", "AdminEnrollments", new { id = e.Id })">Tühista</a>
                    }
                    <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("EmailTraining", "AdminEnrollments", new { id = e.Training.Id })">
                        Saada e-kiri grupile
                    </a>
                </td>
            </tr>
        }
    </table>
}
