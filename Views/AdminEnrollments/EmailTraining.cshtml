@model KeeleSystem.Models.TrainingEmailViewModel

@{
    ViewBag.Title = "Saada e-kiri";
}

<h2>Saada e-kiri koolitusele</h2>

<div class="alert alert-light">
    <strong>Koolitus:</strong> @Model.CourseName<br />
    <strong>Õpetaja:</strong> @Model.TeacherName<br />
    <strong>Algus:</strong> @Model.AlgusKuupaev.ToShortDateString()<br />
    <strong>Saajaid:</strong> @Model.RecipientCount
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.TrainingId)

    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="mb-3">
        @Html.LabelFor(m => m.Subject, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Subject, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Subject, "", new { @class = "text-danger" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Body, new { @class = "form-label" })
        @Html.TextAreaFor(m => m.Body, 6, 40, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Body, "", new { @class = "text-danger" })
    </div>

    <button type="submit" class="btn btn-primary">Saada e-kiri</button>
    <a href="@Url.Action("Index", "AdminEnrollments")" class="btn btn-outline-secondary ms-2">Tagasi</a>
}
